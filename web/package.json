{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:mobile": "vue-tsc -b && cross-env VITE_API_BASE_URL=https://study.leshen.cloud vite build",
    "cap:sync": "npm run build:mobile && cap sync android",
    "cap:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@headlessui/vue": "^1.7.23",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.16.1",
    "dompurify": "^3.4.10",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@lucide/vue": "^1.17.0",
    "@playwright/test": "^1.60.0",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.10.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.8"
  }
